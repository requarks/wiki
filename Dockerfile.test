ARG NODE_IMAGE=node:20-alpine
FROM ${NODE_IMAGE} AS test

WORKDIR /wiki

# NOTE: CI runners may block outbound access to Alpine package repositories.
# Avoid `apk add` here so Docker builds don't fail in restricted environments.
# The provided NODE_IMAGE is expected to already contain the required toolchain
# (node + yarn) and any build tooling needed for native dependencies.

# Copy only dependency files first for better caching
COPY package.json yarn.lock ./

# Install all dependencies (including devDependencies for testing)
RUN yarn install --frozen-lockfile --non-interactive

# Now copy the rest of the code (only what's needed for tests)
COPY jest.config.js ./
COPY ./server ./server

#RUN mkdir -p /wiki/coverage && chown -R node:node /wiki/coverage

# Default command (can be overridden)
CMD ["yarn", "jest", "--config=jest.config.js", "--coverage"]
